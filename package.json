{
    "name": "hsichen.dev",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "smoke": "node scripts/smoke-create-hsi-app.mjs",
        "check": "tsc -p tsconfig.json --noEmit && eslint . && prettier . --check && next build"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,scss,html,json,md,yml,yaml}": [
            "prettier --write"
        ],
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix"
        ]
    },
    "dependencies": {
        "next": "16.2.7",
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "complete-lint": "5.12.0",
        "eslint": "10.4.1",
        "eslint-config-complete": "4.8.0",
        "eslint-import-resolver-typescript": "4.4.5",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "3.8.3",
        "typescript": "6.0.3",
        "@next/eslint-plugin-next": "16.2.7"
    },
    "packageManager": "bun@1.3.9"
}
